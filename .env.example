# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# ============================================================
# Required — the app will refuse to start without these
# ============================================================

# Flask secret key (must be identical across all workers/processes)
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# API access token
API_TOKEN=CHANGE_ME

# Initial admin password (required on first run; NO default fallback)
INIT_ADMIN_PASSWORD=

# ============================================================
# Database — at least one must be configured
# ============================================================

# PostgreSQL (production)
DATABASE_URL=postgresql://station_monitor:CHANGE_ME@127.0.0.1:5432/station_monitor

# SQLite (local dev only; ignored when DATABASE_URL is set)
# DATABASE_PATH=./data/station_monitor.db

# ============================================================
# Runtime directories
# ============================================================

APP_DATA_DIR=./data
PHOTO_ROOT_PATH=./photos
DATA_SOURCE_PATH=./source_docs

# ============================================================
# Flask settings
# ============================================================

FLASK_DEBUG=False
# Set to True when running behind HTTPS
SESSION_COOKIE_SECURE=False

# ============================================================
# Docker / deployment
# ============================================================

POSTGRES_DATA_DIR=./docker/postgres
APP_DATA_HOST_DIR=./data
PHOTO_ROOT_HOST_DIR=./photos
DATA_SOURCE_HOST_DIR=./source_docs
ENV_FILE_PATH=./.env
PYTHON_BASE_IMAGE=python:3.11-slim

# ============================================================
# NVIDIA AI integration (optional)
# ============================================================

FAULT_AI_ENABLED=false
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
FAULT_AI_TIMEOUT_SECONDS=20

# ============================================================
# Map tiles
# ============================================================

MAP_TILE_URL=https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}
MAP_TILE_ATTRIBUTION=高德地图
MAP_TILE_SUBDOMAINS=1,2,3,4
MAP_TILE_MAX_ZOOM=18
MAP_TILE_FALLBACK_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_FALLBACK_ATTRIBUTION=OpenStreetMap
MAP_TILE_FALLBACK_SUBDOMAINS=a,b,c
MAP_TILE_FALLBACK_MAX_ZOOM=18
