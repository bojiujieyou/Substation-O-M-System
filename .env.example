# Copy this file to .env and fill in real values.

# API access token
API_TOKEN=your_secret_token_here

# Flask debug mode
FLASK_DEBUG=False

# Docker base image override
# Use this on NAS/fnOS if the default docker.io mirror is unavailable.
# Example: PYTHON_BASE_IMAGE=<your-accessible-python-3.11-slim-image>
PYTHON_BASE_IMAGE=python:3.11-slim

# NVIDIA AI integration
# If NVIDIA_API_KEY is empty, the app falls back to rule-based import behavior.
FAULT_AI_ENABLED=true
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
FAULT_AI_TIMEOUT_SECONDS=20

# Map tiles
# Default primary provider is AutoNavi, with OpenStreetMap as fallback.
MAP_TILE_URL=https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}
MAP_TILE_ATTRIBUTION=高德地图
MAP_TILE_SUBDOMAINS=1,2,3,4
MAP_TILE_MAX_ZOOM=18
MAP_TILE_FALLBACK_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_FALLBACK_ATTRIBUTION=OpenStreetMap
MAP_TILE_FALLBACK_SUBDOMAINS=a,b,c
MAP_TILE_FALLBACK_MAX_ZOOM=18
